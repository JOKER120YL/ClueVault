<Window x:Class="ClueVault.Desktop.EditSubmissionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="补充说明"
        Width="680"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFBF5">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock x:Name="TitleText" FontSize="26" FontWeight="Bold" Foreground="#1F2328" />
            <TextBlock Text="保存后将同步更新共享盘中的归档信息。" Margin="0,6,0,0" Foreground="#5B636B" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="项目名（选填）" Margin="0,0,0,6" />
            <TextBox x:Name="ProjectNameTextBox" Height="42" Padding="12,10" Margin="0,0,0,14" />

            <TextBlock Text="问题描述" Margin="0,0,0,6" />
            <TextBox x:Name="DescriptionTextBox" Height="180" Padding="12" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="110" Height="44" Margin="0,0,10,0" Click="Cancel_Click">取消</Button>
            <Button Width="120" Height="44" Background="#1C6C59" Foreground="White" BorderThickness="0" Click="Save_Click">保存</Button>
        </StackPanel>
    </Grid>
</Window>
