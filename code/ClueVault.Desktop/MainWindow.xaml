<Window x:Class="ClueVault.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClueVault"
        Width="1240"
        Height="820"
        MinWidth="1060"
        MinHeight="700"
        Icon="Assets/app-icon.ico"
        Background="#F3EFE7">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#102D25" />
        <SolidColorBrush x:Key="MutedBrush" Color="#61716B" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#176B58" />
        <SolidColorBrush x:Key="LineBrush" Color="#D9E2D8" />
        <SolidColorBrush x:Key="PaperBrush" Color="#FFFDF7" />

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E8F1EC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="BorderBrush" Value="#D7E0D8" />
            <Setter Property="Background" Value="#FFFDF7" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#176B58" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#176B58" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFDF7" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FBF8F0" BorderBrush="#E1D8C8" BorderThickness="0,0,1,0" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <Border Width="42" Height="42" HorizontalAlignment="Left" Background="#176B58" CornerRadius="12" Margin="0,0,0,12">
                        <TextBlock Text="CV" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                    </Border>
                    <TextBlock Text="ClueVault" FontSize="18" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="模型归档助手" FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="ArchiveNavButton" Style="{StaticResource NavButtonStyle}" Tag="Archive" Click="Nav_Click" Background="#E8F1EC">快速归档</Button>
                    <Button x:Name="RecordsNavButton" Style="{StaticResource NavButtonStyle}" Tag="Records" Click="Nav_Click">今日记录</Button>
                    <Button x:Name="KnowledgeNavButton" Style="{StaticResource NavButtonStyle}" Tag="Knowledge" Click="Nav_Click">经验库</Button>
                    <Button x:Name="ConfigNavButton" Style="{StaticResource NavButtonStyle}" Tag="Config" Click="Nav_Click">配置中心</Button>
                    <Button x:Name="AboutNavButton" Style="{StaticResource NavButtonStyle}" Tag="About" Click="Nav_Click">关于</Button>
                </StackPanel>

                <Border Grid.Row="2" Background="#FFFDF7" BorderBrush="#E1D8C8" BorderThickness="1" CornerRadius="16" Padding="14">
                    <StackPanel>
                        <TextBlock Text="今日归档" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                        <TextBlock x:Name="WidgetStateText" Text="今日已归档 0 个" FontSize="18" FontWeight="Bold" Foreground="{StaticResource InkBrush}" Margin="0,10,0,0" />
                        <Border x:Name="WidgetStateBadge" Background="#E8F1EC" CornerRadius="14" Padding="10,7" Margin="0,10,0,0">
                            <TextBlock x:Name="WidgetAvatarText" Text="当前形象：蛙弟" Foreground="#176B58" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="通过悬浮窗或托盘菜单可打开主窗口。" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,24">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="ViewEyebrowText" Text="ClueVault" FontSize="13" FontWeight="SemiBold" Foreground="#B86B26" />
                    <TextBlock x:Name="ViewTitleText" Text="快速归档" FontSize="34" FontWeight="Bold" Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
                    <TextBlock x:Name="ViewDescriptionText" Text="将模型文件归档到共享盘专业目录。" FontSize="15" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <Grid x:Name="ArchiveView">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Border x:Name="DropZone"
                                AllowDrop="True"
                                DragEnter="DropZone_DragEnter"
                                DragLeave="DropZone_DragLeave"
                                DragOver="DropZone_DragOver"
                                Drop="DropZone_Drop"
                                Background="#F8FCF9"
                                BorderBrush="#BFD7CA"
                                BorderThickness="1"
                                CornerRadius="26"
                                Padding="32"
                                Margin="0,0,20,18">
                            <StackPanel>
                                <TextBlock Text="添加模型文件" FontSize="26" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="选择文件和专业后即可归档，备注为可选信息。" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="15" Margin="0,10,0,22" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Width="170" Height="48" Click="Submit_Click">归档到共享盘</Button>
                                    <Button Style="{StaticResource GhostButtonStyle}" Width="132" Height="48" Margin="10,0,0,0" Click="ChooseFiles_Click">选择文件</Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource PaperBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="24" Padding="24" Margin="0,0,20,0">
                            <StackPanel>
                                <TextBlock Text="归档专业" FontSize="17" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="请选择本次归档的目标专业。" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,4,0,12" />
                                <WrapPanel x:Name="DisciplinePanel" />
                                <WrapPanel x:Name="QuickDisciplinePanel" Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="WidgetQuickPanel" Background="#EAF5EF" BorderBrush="#CDE0D5" BorderThickness="1" CornerRadius="20" Padding="16" Margin="0,18,20,0" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="已添加文件" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                <TextBlock x:Name="WidgetQuickText" Margin="0,6,0,10" Foreground="{StaticResource MutedBrush}" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="42" Click="QuickSubmit_Click">归档</Button>
                                    <Button Style="{StaticResource GhostButtonStyle}" Width="100" Height="42" Margin="10,0,0,0" Click="DismissQuickPanel_Click">关闭</Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Border Background="{StaticResource PaperBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="24" Padding="24">
                            <StackPanel>
                                <TextBlock Text="待归档文件" FontSize="18" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="已添加的文件将随本次归档写入共享盘。" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,4,0,14" />
                                <ListBox x:Name="AttachmentList"
                                         MinHeight="210"
                                         MaxHeight="300"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F7FBF8" BorderBrush="#DDE7DF" BorderThickness="1" CornerRadius="14" Margin="0,0,0,8" Padding="12">
                                                <DockPanel LastChildFill="False">
                                                    <StackPanel DockPanel.Dock="Left" Width="210">
                                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                                                        <TextBlock Text="{Binding Role}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                                    </StackPanel>
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Padding="10,6" Tag="{Binding}" Click="RemoveAttachment_Click">移除</Button>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource PaperBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="24" Padding="24" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="附加信息" FontSize="18" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="可记录项目名称和补充说明。" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,4,0,14" />
                                <TextBlock Text="项目名" Foreground="{StaticResource MutedBrush}" FontSize="13" />
                                <TextBox x:Name="ProjectNameTextBox" Height="38" Margin="0,5,0,12" Padding="10,8" BorderBrush="{StaticResource LineBrush}" />
                                <TextBlock Text="备注" Foreground="{StaticResource MutedBrush}" FontSize="13" />
                                <TextBox x:Name="DescriptionTextBox" Height="86" Margin="0,5,0,12" Padding="10,8" BorderBrush="{StaticResource LineBrush}" TextWrapping="Wrap" AcceptsReturn="True" />
                                <TextBlock x:Name="BugStatusText" Foreground="#176B58" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="RecordsView" Visibility="Collapsed">
                    <Border Background="{StaticResource PaperBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="26" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock Text="今日归档记录" FontSize="24" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="查看归档目录、专业分类和提交时间。" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
                            </StackPanel>
                            <ListBox x:Name="HistoryList" Grid.Row="1" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8FCF9" BorderBrush="#DDE7DF" BorderThickness="1" CornerRadius="18" Margin="0,0,0,10" Padding="16">
                                            <DockPanel LastChildFill="True">
                                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Width="96" Height="38" Tag="{Binding}" Click="EditHistory_Click">改备注</Button>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FolderName}" FontWeight="Bold" Foreground="{StaticResource InkBrush}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding DisciplineLabel}" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0" />
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                                    <TextBlock Text="{Binding TargetDirectory}" Foreground="#6D7D76" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="KnowledgeView" Visibility="Collapsed">
                    <Border Background="{StaticResource PaperBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="26" Padding="24">
                        <StackPanel>
                            <TextBlock Text="经验库" FontSize="24" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                            <TextBlock Text="沉淀可复用的用户问答和处理经验。" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,22" />
                            <Border Background="#F8FCF9" BorderBrush="#DDE7DF" BorderThickness="1" CornerRadius="20" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="经验管理" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="记录用户问题、回复方式和适用场景。支持导入和导出经验库。" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                        <Button Style="{StaticResource GhostButtonStyle}" Width="130" Height="42">导入经验库</Button>
                                        <Button Style="{StaticResource GhostButtonStyle}" Width="130" Height="42" Margin="10,0,0,0">导出经验库</Button>
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="42" Margin="10,0,0,0">新增经验</Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="ConfigView" Visibility="Collapsed">
                    <Border Background="{StaticResource PaperBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="26" Padding="24">
                        <StackPanel>
                            <TextBlock Text="配置中心" FontSize="24" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                            <TextBlock Text="管理基础信息、共享盘目录和悬浮窗状态。" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,22" />
                            <UniformGrid Columns="2" Margin="0,0,0,18">
                                <Border Background="#F8FCF9" BorderBrush="#DDE7DF" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="使用者" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                                        <TextBlock x:Name="ConfigNameText" Text="未配置" Foreground="{StaticResource MutedBrush}" FontSize="16" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#F8FCF9" BorderBrush="#DDE7DF" BorderThickness="1" CornerRadius="18" Padding="18" Margin="10,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="蜂哥切换" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                                        <TextBlock x:Name="ConfigThresholdText" Text="阈值 1 次" Foreground="{StaticResource MutedBrush}" FontSize="16" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#F8FCF9" BorderBrush="#DDE7DF" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,10,10,0">
                                    <StackPanel>
                                        <TextBlock Text="共享盘目录" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                                        <TextBlock x:Name="ConfigStorageText" Text="未配置" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#F8FCF9" BorderBrush="#DDE7DF" BorderThickness="1" CornerRadius="18" Padding="18" Margin="10,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="悬浮窗" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                                        <TextBlock Text="已启用" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="46" Click="Settings_Click">编辑配置</Button>
                                <Button Style="{StaticResource GhostButtonStyle}" Width="150" Height="46" Margin="10,0,0,0" Click="CreateShortcut_Click">创建桌面快捷方式</Button>
                                <TextBlock Text="保存后将应用到新的归档记录。" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Margin="16,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="AboutView" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="{StaticResource PaperBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="26" Padding="24" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="关于 ClueVault" FontSize="24" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="模型归档助手，用于将用户模型材料归档到共享盘专业目录。" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,22" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="当前版本" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,14" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AboutVersionText" Text="v0.2.0" FontWeight="Bold" Foreground="{StaticResource InkBrush}" Margin="0,0,0,14" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="项目地址" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,14" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="github.com/JOKER120YL/ClueVault" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,0,0,14" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="更新渠道" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="GitHub Releases" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                                        <Button Style="{StaticResource GhostButtonStyle}" Width="128" Height="42" Click="OpenProject_Click">打开项目主页</Button>
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Width="128" Height="42" Margin="10,0,0,0" Click="OpenReleases_Click">检查更新</Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource PaperBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="26" Padding="24">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,14">
                                        <TextBlock Text="更新日志" FontSize="22" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                        <TextBlock DockPanel.Dock="Right" Text="v0.2.0" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                                    </DockPanel>
                                    <Border Background="#F8FCF9" BorderBrush="#DDE7DF" BorderThickness="1" CornerRadius="18" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="新增悬浮窗极速归档流程。" Foreground="{StaticResource InkBrush}" Margin="0,0,0,8" />
                                            <TextBlock Text="新增专业目录归档和归档信息.md 输出。" Foreground="{StaticResource InkBrush}" Margin="0,0,0,8" />
                                            <TextBlock Text="新增系统托盘入口、悬浮窗右键菜单和退出功能。" Foreground="{StaticResource InkBrush}" Margin="0,0,0,8" />
                                            <TextBlock Text="新增关于页面、版本信息和 GitHub Releases 更新入口。" Foreground="{StaticResource InkBrush}" Margin="0,0,0,8" />
                                            <TextBlock Text="优化主窗口信息架构和任务栏图标。" Foreground="{StaticResource InkBrush}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
