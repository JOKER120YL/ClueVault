<Window x:Class="ClueVault.Desktop.QuickArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速归档"
        Width="360"
        Height="540"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="Assets/app-icon.ico"
        ShowInTaskbar="False">
    <Border Background="#FFFDF8" CornerRadius="24" Padding="18" BorderBrush="#D8E5DC" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="10" Color="#1D2A24" Opacity="0.16" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="快速归档" FontSize="22" FontWeight="Bold" Foreground="#102D25" />
                <TextBlock x:Name="SummaryText" Margin="0,8,0,0" Foreground="#5B636B" FontSize="14" TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                <TextBlock Text="待归档文件" FontSize="14" FontWeight="SemiBold" Foreground="#394047" Margin="0,0,0,8" />
                <ItemsControl x:Name="AttachmentList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F7FBF8" BorderBrush="#D8E5DC" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                                <DockPanel>
                                    <TextBlock Text="{Binding Name}" Foreground="#1F2328" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Role}" DockPanel.Dock="Right" Foreground="#6B635A" FontSize="12" Margin="10,0,0,0" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button x:Name="PasteScreenshotButton" Height="36" Margin="0,4,0,10" Click="PasteScreenshot_Click">粘贴剪贴板截图</Button>

                <TextBlock Text="归档专业 *" FontSize="14" Foreground="#394047" Margin="0,8,0,10" />
                <WrapPanel x:Name="DisciplinePanel" />

                <Expander Header="更多信息（可不填）" Margin="0,8,0,0">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="项目名" FontSize="13" Foreground="#6B635A" />
                        <TextBox x:Name="ProjectNameTextBox" Height="38" Margin="0,4,0,10" Padding="10,8" BorderBrush="#D8C9B7" />
                        <TextBlock Text="来源" FontSize="13" Foreground="#6B635A" />
                        <TextBox x:Name="SourceTextBox" Height="38" Margin="0,4,0,10" Padding="10,8" BorderBrush="#D8C9B7" Text="微信群" />
                        <TextBlock Text="备注" FontSize="13" Foreground="#6B635A" />
                        <TextBox x:Name="RemarkTextBox" Height="82" Margin="0,4,0,0" Padding="10,8" BorderBrush="#D8C9B7" TextWrapping="Wrap" AcceptsReturn="True" />
                    </StackPanel>
                </Expander>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="CancelButton" Width="88" Height="44" Margin="0,0,10,0" Click="Cancel_Click">取消</Button>
                <Button x:Name="SubmitButton" Width="170" Height="44" Background="#1C6C59" Foreground="White" BorderThickness="0" Click="Submit_Click">归档到共享盘</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
